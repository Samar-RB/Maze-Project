<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/18" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.last_version.numofrowsandcolsController">
   <children>
      <Label layoutX="12.0" layoutY="150.0" text="Num of Rows :" textFill="#42bda1">
         <font>
            <Font name="System Bold Italic" size="14.0" />
         </font></Label>
      <Label layoutX="14.0" layoutY="200.0" text="Num Of Cols :" textFill="#42bda1">
         <font>
            <Font name="System Bold Italic" size="14.0" />
         </font></Label>
      <TextField fx:id="textField_mazeRows" layoutX="115.0" layoutY="146.0" />
      <TextField fx:id="textField_mazeColumns" layoutX="115.0" layoutY="196.0" />
      <Button layoutX="232.0" layoutY="291.0" mnemonicParsing="false" onAction="#generatefirstmaze" text="Generate Maze" textFill="#bd42b0">
         <font>
            <Font name="System Bold Italic" size="14.0" />
         </font></Button>
      <Label layoutX="14.0" layoutY="59.0" text="Welcome! Please give us the number of rows and the number of columns you want." textFill="#bd42b2">
         <font>
            <Font name="System Bold Italic" size="14.0" />
         </font>
      </Label>
   </children>
</AnchorPane>
